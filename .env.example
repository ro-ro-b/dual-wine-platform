# DUAL SDK Configuration
# Set NEXT_PUBLIC_DUAL_CONFIGURED=true and provide credentials to use live DUAL data
# When false, the app uses demo data (12 sample wines)
NEXT_PUBLIC_DUAL_CONFIGURED=false
NEXT_PUBLIC_DUAL_API_URL=https://blockv-labs.io
DUAL_API_TOKEN=
DUAL_ORG_ID=
DUAL_TEMPLATE_ID=
DUAL_WEBHOOK_SECRET=
DUAL_WEBHOOK_CALLBACK_URL=

# AI Asset Generation (Google Gemini)
# Single key for both image (Nano Banana) and video (Veo) generation
# Get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# App Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
