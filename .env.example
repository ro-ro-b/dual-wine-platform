# DUAL Network Configuration
# Set DUAL_CONFIGURED=true to connect to the live DUAL network
# When false, the app uses demo data (12 sample wines)
DUAL_CONFIGURED=false

# DUAL API Credentials (required when DUAL_CONFIGURED=true)
DUAL_API_URL=https://api.dual.io
DUAL_API_KEY=
DUAL_ORG_ID=
DUAL_TEMPLATE_ID=
DUAL_WEBHOOK_SECRET=
DUAL_WEBHOOK_CALLBACK_URL=

# App Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
